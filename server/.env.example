# GradeOps Backend Environment Variables

# Application Settings
APP_NAME=GradeOps
DEBUG=False
HOST=0.0.0.0
PORT=8000

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/gradeops
DB_ECHO=False
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Supabase
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=your-supabase-api-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Storage
SUPABASE_STORAGE_EXAM_PDFS_BUCKET=exam-pdfs
SUPABASE_STORAGE_ANSWER_IMAGES_BUCKET=answer-images

# OpenAI API
OPENAI_API_KEY=sk-xxx...
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7

# Sentence Transformers (for embeddings)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Plagiarism Detection
PLAGIARISM_THRESHOLD=0.85
PLAGIARISM_TOP_K=5

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://localhost:3000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Upload
MAX_UPLOAD_SIZE_MB=50
ALLOWED_FILE_TYPES=pdf

# Pipeline
PIPELINE_TIMEOUT_SECONDS=300
PIPELINE_RETRY_COUNT=2
